# Copy to .env.local and fill in real values. Referenced by docker-compose.yml (env_file).
# These configure the /admin content manager — see lib/auth.ts.

# TEMP (test): staging/test switch — see lib/test-mode.ts. When "true":
#   - the public form/API routes (contact, job application, upload) return 503
#   - public phone numbers and email are replaced with placeholders
# Leave unset or "false" in production.
SITE_TEST_MODE=true

# Admin login credentials. Change them — the in-code defaults are insecure dev fallbacks.
ADMIN_EMAIL=admin@fliesen-aman.de
ADMIN_PASSWORD=change-me-please

# Secret used to sign the admin session cookie (HMAC-SHA256).
# Generate a strong value, e.g.:  openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-a-long-random-string


# SMTP for the website forms (contact, job applications, project planner) — see lib/email.ts.
# SMTP_EMAIL/SMTP_PASSWORD are required; the rest have sensible defaults.
SMTP_EMAIL=info@fliesen-aman.de
SMTP_PASSWORD=
# SMTP server. The mailbox is hosted at IONOS, whose outgoing server is smtp.ionos.de.
SMTP_HOST=smtp.ionos.de
# Port 465 = implicit TLS (default), 587 = STARTTLS (also set SMTP_SECURE=false).
SMTP_PORT=465
SMTP_SECURE=true
# Where form submissions are delivered. Defaults to SMTP_EMAIL.
# MAIL_TO=info@fliesen-aman.de
# Display name on the From header.
# MAIL_FROM_NAME=Fliesen & Naturstein Aman